# Base de datos (Postgres). En local apunta al contenedor de docker-compose.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/escuelitas_fut"

# Secreto para firmar las sesiones de Auth.js.
# Genera uno con: openssl rand -base64 32
AUTH_SECRET=""

# Login con Google (opcional). Si se dejan vacíos, solo habrá correo/contraseña.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe (se usa en la fase de pagos).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
